# ──────────────────────────────────────────────────────────────────────────────
# Signage API — Pi production environment template
# Copy to /etc/signage/api.env and fill in all CHANGE_ME values.
# NEVER commit the real api.env — only this example file is tracked.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL 17 — DB: ds, role: signage
# Create on Pi: sudo -u postgres psql -c "CREATE USER signage WITH PASSWORD '...';"
# then: CREATE DATABASE ds OWNER signage; GRANT ALL ON SCHEMA public TO signage;
DATABASE_URL=postgresql://signage:CHANGE_ME@localhost:5432/ds

# Redis (localhost — requirepass set in /etc/redis/redis.conf)
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_32_OR_MORE_RANDOM_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_32_OR_MORE_RANDOM_CHARACTERS

# File storage
STORAGE_ROOT=/var/signage/uploads

# External tool paths (installed via apt in bootstrap.sh)
FFMPEG_PATH=ffmpeg
LIBREOFFICE_PATH=soffice
GHOSTSCRIPT_PATH=gs

# Playwright browser cache (installed by install-system-packages.sh to shared path)
PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers

# Public URL and allowed CORS origins
APP_URL=https://ds.chiho.app
APP_EXTRA_ORIGINS=http://192.168.1.17

# API server port (nginx proxies /api/ → localhost:3000)
API_PORT=3000

# Node.js heap cap — prevents the API from accidentally consuming all Pi RAM
# during heavy media processing (ffmpeg, sharp, soffice all spawn subprocesses).
# 512 MB is comfortable for Pi 5 with Postgres + Redis on the same host.
NODE_OPTIONS=--max-old-space-size=512

# Set to false when the Pi is accessed over plain HTTP on the LAN (192.168.x.x).
# Cookies are Secure by default (HTTPS only); disabling lets the LAN HTTP origin work too.
COOKIE_SECURE=false

# SMTP — use an app password, not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM=CHANGE_ME@gmail.com

# ── Calendar OAuth ─────────────────────────────────────────────────────────────
# Google Calendar — console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Redirect URI to register: https://<your-domain>/api/v1/integrations/calendar/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft Outlook — portal.azure.com → Entra ID → App registrations
# Redirect URI to register: https://<your-domain>/api/v1/integrations/calendar/oauth/microsoft/callback
# Permissions needed (Delegated): Calendars.Read, User.Read, offline_access
MICROSOFT_OAUTH_CLIENT_ID=CHANGE_ME
MICROSOFT_OAUTH_CLIENT_SECRET=CHANGE_ME
# Use 'common' to support both personal and work/school Microsoft accounts
MICROSOFT_OAUTH_TENANT=common

# Token encryption key (AES-256-GCM) — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
