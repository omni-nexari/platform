DATABASE_URL=postgresql://signage:signage_dev_pw@localhost:5432/signage_dev
REDIS_URL=redis://:your_redis_password@192.168.1.17:6379
JWT_SECRET=change_me_to_32_or_more_random_characters
JWT_REFRESH_SECRET=change_me_to_a_different_32_or_more_random_characters
STORAGE_ROOT=C:/signage_uploads
RESEND_API_KEY=re_your_api_key
RESEND_FROM_ADMIN=admin@mail.chiho.app
RESEND_FROM_MAIL=mail@mail.chiho.app
FFMPEG_PATH=ffmpeg
LIBREOFFICE_PATH=soffice
GHOSTSCRIPT_PATH=gswin64c
APP_URL=http://localhost:5173
API_PORT=3000

# Uber Eats OAuth app credentials
# Can be set here OR configured via superadmin UI (POST /api/v1/superadmin/integrations/uber_eats).
# If both are set, the DB value takes precedence.
# UBER_CLIENT_ID=
# UBER_CLIENT_SECRET=
UBER_REDIRECT_URI=https://your-api-domain.com/api/v1/pos/uber-eats/oauth/callback

# Encryption key for secrets stored at rest in the database (OAuth tokens, integration credentials).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
