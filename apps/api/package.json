{
  "name": "@signage/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @signage/db build",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "prebuild": "pnpm --filter @signage/db build",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretypecheck": "pnpm --filter @signage/db build",
    "typecheck": "tsc --noEmit",
    "seed:sa": "tsx --env-file=$(test -f .env && echo .env || echo /etc/signage/api.env) scripts/seed-superadmin.ts",
    "seed:test": "tsx --env-file=$(test -f .env && echo .env || echo /etc/signage/api.env) scripts/seed-test-org.ts",
    "seed:pos": "tsx --env-file=$(test -f .env && echo .env || echo /etc/signage/api.env) scripts/seed-pos-menu.ts",
    "seed:pos-extras": "tsx --env-file=$(test -f .env && echo .env || echo /etc/signage/api.env) scripts/seed-pos-extras.ts",
    "fix:user-org": "tsx --env-file=$(test -f .env && echo .env || echo /etc/signage/api.env) scripts/fix-user-org.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "@signage/db": "workspace:*",
    "@signage/shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "argon2": "^0.41.1",
    "bullmq": "^5.44.0",
    "drizzle-orm": "^0.40.0",
    "fastify": "^5.3.2",
    "ioredis": "^5.5.0",
    "nanoid": "^5.1.5",
    "nodemailer": "^6.10.1",
    "otplib": "^12.0.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.5",
    "@types/sharp": "^0.32.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
