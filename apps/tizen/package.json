{
  "name": "tizen-signage-player",
  "version": "1.0.0",
  "description": "Nexari Signage — Samsung Smart TV (Tizen 5+)",
  "scripts": {
    "build": "node scripts/generate-build-info.cjs && tsc",
    "build:dev": "cross-env API_BASE=http://192.168.1.110:3000/api/v1 WS_URL=ws://192.168.1.110:3000 node scripts/generate-build-info.cjs && tsc",
    "watch": "node scripts/generate-build-info.cjs && tsc --watch",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/generate-build-info.cjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/generate-build-info.cjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/generate-build-info.cjs"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/tizen-tv-webapis": "^2.0.9",
    "cross-env": "^10.1.0",
    "tizen-tv-webapis": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
