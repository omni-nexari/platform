<?xml version="1.0" encoding="utf-8"?>
<!--
    Device admin policies declared by NexariDeviceAdminReceiver. The receiver
    is also the Device Owner candidate for factory-reset enrolment via QR.
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <limit-password/>
        <watch-login/>
        <reset-password/>
        <force-lock/>
        <wipe-data/>
        <expire-password/>
        <encrypted-storage/>
        <disable-camera/>
        <disable-keyguard-features/>
    </uses-policies>
</device-admin>
