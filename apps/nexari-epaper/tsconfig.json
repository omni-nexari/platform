{
  "compilerOptions": {
    "target": "ES2015",
    "module": "none",
    "lib": ["ES2017", "DOM"],
    "outDir": "./js",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "moduleResolution": "node",
    "types": ["tizen-tv-webapis"],
    "removeComments": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
