{
  "name": "nexari-epaper",
  "version": "0.1.59",
  "description": "Nexari Signage — Samsung E-Paper player (Tizen 8, 32\"/13\" panels, push-first power profile)",
  "scripts": {
    "build": "cross-env API_BASE=https://ds.chiho.app/api/v1 WS_URL=wss://ds.chiho.app node scripts/generate-build-info.cjs",
    "build:dev": "cross-env API_BASE=http://192.168.1.17/api/v1 WS_URL=ws://192.168.1.17 node scripts/generate-build-info.cjs",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/generate-build-info.cjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/generate-build-info.cjs"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/tizen-tv-webapis": "^2.0.9",
    "cross-env": "^10.1.0",
    "tizen-tv-webapis": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
