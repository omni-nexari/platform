{
  "name": "nexari-html5-sync",
  "version": "0.1.0",
  "description": "Nexari HTML5 Sync — group sync with native HTML5 video on Tizen",
  "scripts": {
    "build": "esbuild src/app.ts --bundle --format=iife --target=es2015 --outfile=js/bundle.js",
    "typecheck": "tsc --noEmit",
    "watch": "esbuild src/app.ts --bundle --format=iife --target=es2015 --outfile=js/bundle.js --watch"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/tizen-tv-webapis": "^2.0.9",
    "esbuild": "^0.28.0",
    "tizen-tv-webapis": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
