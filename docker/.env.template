# ─────────────────────────────────────────────────────────────────────────────
# Nexari Platform — Environment Configuration Template
#
# Copy this file to .env and fill in every value.
# Run generate-keys.sh first to obtain random values for the secret fields.
#
# IMPORTANT: Keep .env secret. It contains database passwords and JWT keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Infrastructure secrets (generate with: bash generate-keys.sh) ─────────────

# PostgreSQL password for the signage database user
DB_PASSWORD=

# Redis authentication password
REDIS_PASSWORD=

# JWT signing secrets — must be different from each other, min 64 hex chars each
JWT_SECRET=
JWT_REFRESH_SECRET=

# AES-256 key for encrypting OAuth tokens in the database (exactly 64 hex chars)
TOKEN_ENCRYPTION_KEY=

# ── Application URLs ─────────────────────────────────────────────────────────
# Your domain name (no protocol, no trailing slash)
# Example: signage.mycompany.com
DOMAIN=

# Public-facing base URL for the management portal (used in emails, OAuth callbacks)
APP_URL=https://${DOMAIN}

# Public-facing base URL for the API (used in OAuth redirect URIs + device registration)
API_PUBLIC_URL=https://${DOMAIN}

# ── Email delivery (required for password reset + workspace invitations) ──────
# Resend.com API key — sign up free at https://resend.com
RESEND_API_KEY=

# From address for system emails (must be verified in Resend)
RESEND_FROM_ADMIN=noreply@${DOMAIN}

# From address for user-facing emails (can be same as above)
RESEND_FROM_MAIL=hello@${DOMAIN}

# ── Nexari Admin heartbeat (optional — enables remote monitoring) ─────────────
# License key issued by Nexari. Leave blank to disable heartbeat.
NEXARI_LICENSE_KEY=

# Heartbeat endpoint provided by Nexari
NEXARI_ADMIN_URL=https://admin.nexari.io

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Authorised redirect URI: https://${DOMAIN}/api/v1/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Microsoft OAuth (optional) ────────────────────────────────────────────────
# Create an App Registration at https://portal.azure.com/
# Authorised redirect URI: https://${DOMAIN}/api/v1/auth/microsoft/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

# ── MQTT broker (optional — required for ESP32 / e-paper devices) ─────────────
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Uber Eats integration (optional) ─────────────────────────────────────────
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=

# ── Advanced / performance tuning ─────────────────────────────────────────────

# Set to 1 to skip Playwright/Chromium startup check (saves ~600 MB if HTML5
# package thumbnails are not needed). Must match SKIP_PLAYWRIGHT build arg.
SIGNAGE_SKIP_PLAYWRIGHT=0

# Cookie security — always true behind nginx TLS in production
COOKIE_SECURE=true

# Node.js heap limit in MB. Increase if you have more than 4 GB RAM available.
# Default is 2048 (2 GB). Recommended minimum for 1000+ screens: 4096.
# NODE_OPTIONS is set in docker-compose.yml; override here only if needed.
# NODE_OPTIONS=--max-old-space-size=2048

# Nexari image version to deploy (set automatically by install.sh / update.sh)
NEXARI_VERSION=latest
