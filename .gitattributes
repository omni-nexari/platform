# Force LF line endings for shell scripts and config files on all platforms
*.sh        text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.xml       text eol=lf

# Windows scripts keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
